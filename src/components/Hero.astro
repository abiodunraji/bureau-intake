---
import { url } from '../utils/url';
---

<section class="hero-section" style="min-height: 100vh; display: flex; align-items: center; position: relative; overflow: hidden; padding-top: 120px; background: var(--color-white);">

  <!-- Morph blobs -->
  <div class="morph-blob" aria-hidden="true" style="position: absolute; width: 500px; height: 500px; top: 5%; left: -10%; background: var(--color-accent); opacity: 0.04; pointer-events: none;"></div>
  <div class="morph-blob-slow" aria-hidden="true" style="position: absolute; width: 350px; height: 350px; bottom: 10%; right: -5%; background: var(--color-accent); opacity: 0.03; pointer-events: none;"></div>

  <!-- Parallax floating elements -->
  <div class="parallax-float" aria-hidden="true" style="position: absolute; left: 8%; top: 120px; width: 28px; height: 28px; color: var(--color-accent); opacity: 0.18; pointer-events: none; animation: floatEl 6s ease-in-out infinite;">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="22" x2="12" y2="11"/><path d="M12 11C11 7.5 8 5.5 5 6.5c.3 3.5 2.5 5.5 7 4.5z"/><path d="M12 11c1-3.5 4-5.5 7-4.5-.3 3.5-2.5 5.5-7 4.5z"/></svg>
  </div>
  <div class="parallax-float" aria-hidden="true" style="position: absolute; left: 85%; top: 200px; width: 22px; height: 22px; color: var(--color-accent); opacity: 0.14; pointer-events: none; animation: floatEl 8s ease-in-out 1s infinite;">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2.5"/><ellipse cx="12" cy="5.5" rx="2" ry="3"/><ellipse cx="18.5" cy="12" rx="3" ry="2"/><ellipse cx="12" cy="18.5" rx="2" ry="3"/><ellipse cx="5.5" cy="12" rx="3" ry="2"/></svg>
  </div>
  <div class="parallax-float" aria-hidden="true" style="position: absolute; left: 92%; top: 400px; width: 24px; height: 24px; color: var(--color-accent); opacity: 0.10; pointer-events: none; animation: floatEl 7s ease-in-out 2s infinite;">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="22" x2="12" y2="5"/><path d="M12 14c-1-2.5-4-4-7-3 .3 3 2.5 5 7 3z"/><path d="M12 14c1-2.5 4-4 7-3-.3 3-2.5 5-7 3z"/><path d="M12 8c-1-2-3-3-5-2.5.2 2.5 2 4 5 2.5z"/><path d="M12 8c1-2 3-3 5-2.5-.2 2.5-2 4-5 2.5z"/></svg>
  </div>
  <div class="parallax-float" aria-hidden="true" style="position: absolute; left: 5%; top: 500px; width: 20px; height: 20px; color: var(--color-accent); opacity: 0.10; pointer-events: none; animation: floatEl 9s ease-in-out 0.5s infinite;">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13C8 11 8 8 10 6s5-2 7 0"/><path d="M14 11c2 2 2 5 0 7s-5 2-7 0"/><line x1="14" y1="6" x2="14" y2="4"/><line x1="10" y1="20" x2="10" y2="22"/></svg>
  </div>

  <div class="hero-inner" style="max-width: 1300px; margin: 0 auto; padding: 0 24px; width: 100%; display: flex; align-items: center; gap: 56px; flex-wrap: wrap; justify-content: space-between;">

    <!-- Left: copy -->
    <div style="flex: 1 1 440px; max-width: 660px;">

      <!-- Eyebrow with line -->
      <div class="hero-sub" style="display: flex; align-items: center; gap: 10px; margin-bottom: 24px;">
        <div style="width: 28px; height: 1.5px; background: var(--color-accent); flex-shrink: 0;"></div>
        <span style="font-size: 12px; font-weight: 600; letter-spacing: 0.12em; color: var(--color-accent); text-transform: uppercase; font-family: var(--font-body);">
          Lokale vindbaarheid voor fysiotherapeuten
        </span>
      </div>

      <!-- Headline -->
      <h1 class="hero-h1" style="font-size: clamp(34px, 5.5vw, 72px); font-weight: 700; line-height: 1.08; letter-spacing: -0.03em; color: var(--color-primary); margin-bottom: 28px;">
        Elke dag zoeken patiënten naar een fysiotherapeut in jouw regio.<br />
        <span style="font-style: italic; color: #9ca3af; font-weight: 400;">
          De vraag is of ze jou vinden.
        </span>
      </h1>

      <!-- Subtitle -->
      <p class="hero-sub" style="font-size: clamp(16px, 1.5vw, 19px); line-height: 1.7; color: var(--color-muted); max-width: 520px; margin-bottom: 36px;">
        Wij maken fysiotherapiepraktijken zichtbaar in Google, Google Maps en AI-zoekmachines.
      </p>

      <!-- CTAs -->
      <div class="hero-cta" style="display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 32px;">
        <a
          href={url('/contact')}
          style="font-family: var(--font-body); font-size: 15px; font-weight: 600; color: white; background: var(--color-accent); padding: 16px 36px; border-radius: 10px; text-decoration: none; box-shadow: 0 4px 20px rgba(46,204,113,0.25); display: inline-block; transition: all 0.25s ease;"
          onmouseover="this.style.background='var(--color-accent-hover)'; this.style.transform='translateY(-1px)'; this.style.boxShadow='0 8px 28px rgba(46,204,113,0.3)';"
          onmouseout="this.style.background='var(--color-accent)'; this.style.transform=''; this.style.boxShadow='0 4px 20px rgba(46,204,113,0.25)';"
        >
          Plan een kennismaking
        </a>
        <a
          href="#hoe-het-werkt"
          style="font-family: var(--font-body); font-size: 15px; font-weight: 500; color: var(--color-primary); padding: 16px 20px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: color 0.2s ease;"
          onmouseover="this.style.color='var(--color-accent)'"
          onmouseout="this.style.color='var(--color-primary)'"
        >
          Hoe werkt het? →
        </a>
      </div>

      <!-- Trust badges -->
      <div class="hero-cta" style="display: flex; gap: 10px; flex-wrap: wrap;">
        <span style="font-family: var(--font-body); font-size: 12px; font-weight: 500; color: var(--color-primary); padding: 6px 14px; background: rgba(46,204,113,0.07); border-radius: 20px; border: 1px solid rgba(46,204,113,0.12);">✓ Maandelijks opzegbaar</span>
        <span style="font-family: var(--font-body); font-size: 12px; font-weight: 500; color: var(--color-primary); padding: 6px 14px; background: rgba(46,204,113,0.07); border-radius: 20px; border: 1px solid rgba(46,204,113,0.12);">✓ Geen opstartkosten</span>
      </div>
    </div>

    <!-- Right: HeroCard — cycling animation -->
    <div class="hero-cta hero-card-wrap" style="flex: 0 1 400px; min-width: 260px; position: relative;" aria-hidden="true">

      <!-- Morph blob behind card -->
      <div class="morph-blob-slow" style="position: absolute; width: 260px; height: 260px; top: -30px; right: -40px; background: var(--color-accent); opacity: 0.07; pointer-events: none;"></div>
      <div class="morph-blob-slower" style="position: absolute; width: 180px; height: 180px; bottom: -20px; left: -30px; background: var(--color-accent); opacity: 0.04; pointer-events: none;"></div>

      <div
        id="hero-card"
        style="position: relative; background: white; border-radius: 20px; padding: 28px; box-shadow: 0 8px 32px rgba(0,0,0,0.06); border: 1.5px solid rgba(0,0,0,0.04); z-index: 2; transition: all 1.2s cubic-bezier(0.22,1,0.36,1);"
      >
        <!-- Status indicator -->
        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 16px;">
          <div id="card-dot" style="width: 10px; height: 10px; border-radius: 50%; background: #ef4444; transition: all 0.8s ease;"></div>
          <span id="card-status" style="font-family: var(--font-body); font-size: 11px; font-weight: 600; letter-spacing: 0.06em; color: #ef4444; text-transform: uppercase; transition: color 0.8s ease;">Onzichtbaar</span>
        </div>

        <div style="font-family: var(--font-heading); font-size: 19px; font-weight: 700; color: var(--color-primary); margin-bottom: 4px;">Jouw Praktijk</div>
        <div style="font-family: var(--font-body); font-size: 13px; color: #9ca3af; margin-bottom: 16px;">Fysiotherapie · Jouw Stad</div>

        <!-- Stars -->
        <div style="display: flex; gap: 3px; margin-bottom: 6px; align-items: center;">
          <span id="card-star-1" style="font-size: 15px; transition: all 0.5s ease 0ms; opacity: 0.15;">★</span>
          <span id="card-star-2" style="font-size: 15px; transition: all 0.5s ease 80ms; opacity: 0.15;">★</span>
          <span id="card-star-3" style="font-size: 15px; transition: all 0.5s ease 160ms; opacity: 0.15;">★</span>
          <span id="card-star-4" style="font-size: 15px; transition: all 0.5s ease 240ms; opacity: 0.15;">★</span>
          <span id="card-star-5" style="font-size: 15px; transition: all 0.5s ease 320ms; opacity: 0.15;">★</span>
          <span id="card-reviews" style="font-family: var(--font-body); font-size: 12px; color: #9ca3af; margin-left: 6px;">Geen reviews</span>
        </div>

        <!-- Progress -->
        <div style="margin-top: 16px;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
            <span style="font-family: var(--font-body); font-size: 11px; color: #9ca3af;">Profiel compleetheid</span>
            <span id="card-pct" style="font-family: var(--font-body); font-size: 11px; font-weight: 600; color: #ef4444; transition: color 0.8s ease;">15%</span>
          </div>
          <div style="background: #f3f4f6; border-radius: 6px; height: 6px; overflow: hidden;">
            <div id="card-bar" style="height: 100%; border-radius: 6px; background: #ef4444; width: 15%; transition: all 1.4s cubic-bezier(0.22,1,0.36,1);"></div>
          </div>
        </div>

        <!-- Success badge — hidden until phase 2 -->
        <div id="card-badge" style="margin-top: 16px; padding: 10px 14px; background: rgba(46,204,113,0.06); border-radius: 10px; display: none; align-items: center; gap: 8px;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-accent); flex-shrink: 0;" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 11.39 19a19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 3.12 4.18 2 2 0 0 1 5.09 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L9.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span style="font-family: var(--font-body); font-size: 12px; color: var(--color-accent); font-weight: 600;">+3 oproepen deze week</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator" style="position: absolute; bottom: 32px; left: 50%; animation: scrollFloat 3s ease-in-out infinite; flex-direction: column; align-items: center; gap: 8px; opacity: 0.4;" aria-hidden="true">
    <span style="font-family: var(--font-body); font-size: 11px; color: #9ca3af; letter-spacing: 0.1em; text-transform: uppercase;">Scroll</span>
    <div style="width: 1px; height: 24px; background: linear-gradient(to bottom, #9ca3af, transparent);"></div>
  </div>
</section>

<script>
  // HeroCard cycling: Onzichtbaar → Bezig → Gevonden!
  const phases = [
    {
      statusText: 'Onzichtbaar',
      dotColor: '#ef4444',
      statusColor: '#ef4444',
      starsActive: 0,
      reviews: 'Geen reviews',
      pct: '15%',
      barW: '15%',
      barColor: '#ef4444',
      showBadge: false,
      cardBorder: 'rgba(0,0,0,0.04)',
      cardShadow: '0 8px 32px rgba(0,0,0,0.06)',
    },
    {
      statusText: 'Bezig...',
      dotColor: '#f59e0b',
      statusColor: '#f59e0b',
      starsActive: 3,
      reviews: '3 reviews',
      pct: '55%',
      barW: '55%',
      barColor: '#f59e0b',
      showBadge: false,
      cardBorder: 'rgba(0,0,0,0.04)',
      cardShadow: '0 8px 32px rgba(0,0,0,0.06)',
    },
    {
      statusText: 'Gevonden!',
      dotColor: '#2ECC71',
      statusColor: '#2ECC71',
      starsActive: 5,
      reviews: '14 reviews',
      pct: '95%',
      barW: '95%',
      barColor: '#2ECC71',
      showBadge: true,
      cardBorder: 'rgba(46,204,113,0.25)',
      cardShadow: '0 24px 80px rgba(46,204,113,0.12), 0 4px 12px rgba(0,0,0,0.04)',
    },
  ];

  let phase = 0;

  function applyPhase(p: typeof phases[0]) {
    const dot     = document.getElementById('card-dot');
    const status  = document.getElementById('card-status');
    const reviews = document.getElementById('card-reviews');
    const pct     = document.getElementById('card-pct');
    const bar     = document.getElementById('card-bar');
    const badge   = document.getElementById('card-badge') as HTMLElement | null;
    const card    = document.getElementById('hero-card') as HTMLElement | null;

    if (dot)     { dot.style.background = p.dotColor; dot.style.boxShadow = p.showBadge ? `0 0 12px ${p.dotColor}60` : 'none'; }
    if (status)  { status.textContent = p.statusText; status.style.color = p.statusColor; }
    if (reviews) reviews.textContent = p.reviews;
    if (pct)     { pct.textContent = p.pct; pct.style.color = p.barColor; }
    if (bar)     { bar.style.width = p.barW; bar.style.background = `linear-gradient(90deg, ${p.barColor}, ${p.showBadge ? '#27ae60' : p.barColor})`; }
    if (badge)   { badge.style.display = p.showBadge ? 'flex' : 'none'; }
    if (card)    { card.style.borderColor = p.cardBorder; card.style.boxShadow = p.cardShadow; card.style.transform = p.showBadge ? 'translateY(-6px) scale(1.01)' : 'translateY(0) scale(1)'; }

    // Stars
    for (let i = 1; i <= 5; i++) {
      const star = document.getElementById(`card-star-${i}`) as HTMLElement | null;
      if (star) {
        const active = i <= p.starsActive;
        star.style.opacity    = active ? '1' : '0.15';
        star.style.color      = active ? '#f59e0b' : '#d1d5db';
      }
    }
  }

  // Initial apply
  applyPhase(phases[0]);

  setInterval(() => {
    phase = (phase + 1) % phases.length;
    applyPhase(phases[phase]);
  }, 2800);
</script>
