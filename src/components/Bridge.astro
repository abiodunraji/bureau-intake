---
---

<section style="padding: 120px 24px; text-align: center; position: relative; background: var(--color-white);" aria-label="Overbrugging">
  <!-- Morph blob centered -->
  <div class="morph-blob" aria-hidden="true" style="position: absolute; width: 350px; height: 350px; top: 50%; left: 50%; transform: translate(-50%, -50%); background: var(--color-accent); opacity: 0.04; pointer-events: none;"></div>

  <div class="reveal" style="position: relative; max-width: 580px; margin: 0 auto;">
    <!-- Opening quote mark -->
    <div aria-hidden="true" style="font-family: var(--font-heading); font-size: 64px; color: rgba(46,204,113,0.1); line-height: 1; margin-bottom: -16px;">"</div>

    <blockquote style="margin: 0;">
      <p style="font-family: var(--font-heading); font-size: clamp(21px, 3vw, 30px); font-weight: 500; line-height: 1.5; color: var(--color-primary); font-style: italic;">
        Je bent fysiotherapeut geworden om mensen beter te maken — niet om Google-profielen te beheren.
      </p>
      <p style="font-family: var(--font-body); font-size: 17px; color: var(--color-accent); margin-top: 24px; font-weight: 600;">
        En dat hoeft ook niet.
      </p>
    </blockquote>
  </div>
</section>
