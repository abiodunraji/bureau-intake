---
import { url } from '../utils/url';

const navLinks = [
  { href: url('/'), label: 'Home' },
  { href: url('/webdesign'), label: 'Webdesign' },
  { href: url('/blog'), label: 'Blog' },
  { href: url('/over'), label: 'Over ons' },
];

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-[1200px] mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href={url('/')} aria-label="Bureau Intake — home" style="display: inline-flex; align-items: center; text-decoration: none;">
      <picture>
        <source srcset={url('/logo-bi.webp')} type="image/webp" />
        <img src={url('/logo-bi.png')} alt="Bureau Intake" width="167" height="36" fetchpriority="high" decoding="async" style="height: 36px; width: 167px; display: block;" />
      </picture>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Hoofdnavigatie">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="text-sm font-medium transition-colors duration-200 hover:text-[var(--color-accent-text)]"
          style={`color: ${currentPath === link.href ? 'var(--color-accent-text)' : 'var(--color-primary)'}`}
        >
          {link.label}
        </a>
      ))}
      <a
        href={url('/contact')}
        class="text-sm font-semibold px-5 py-2.5 rounded-lg transition-all duration-200 hover:scale-[1.02]"
        style="background: var(--color-accent); color: var(--color-primary);"
        onmouseover="this.style.background='var(--color-accent-hover)'"
        onmouseout="this.style.background='var(--color-accent)'"
      >
        Neem contact op
      </a>
    </nav>

    <!-- Hamburger button -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2 rounded"
      aria-label="Menu openen"
      aria-expanded="false"
    >
      <span class="block w-6 h-0.5 transition-all duration-300" style="background: var(--color-primary);" id="hamburger-1"></span>
      <span class="block w-6 h-0.5 transition-all duration-300" style="background: var(--color-primary);" id="hamburger-2"></span>
      <span class="block w-6 h-0.5 transition-all duration-300" style="background: var(--color-primary);" id="hamburger-3"></span>
    </button>
  </div>
</header>

<!-- Mobile nav panel -->
<div
  id="mobile-nav"
  class="mobile-nav fixed top-0 right-0 h-full w-72 z-40 shadow-2xl flex flex-col pt-24 px-8 gap-6"
  style="background: var(--color-white);"
  inert
>
  {navLinks.map(link => (
    <a
      href={link.href}
      class="text-lg font-medium py-2 border-b transition-colors duration-200 hover:text-[var(--color-accent-text)]"
      style="color: var(--color-primary); border-color: var(--color-light);"
    >
      {link.label}
    </a>
  ))}
  <a
    href={url('/contact')}
    class="mt-4 text-base font-semibold px-6 py-3 rounded-lg text-center transition-all duration-200"
    style="background: var(--color-accent); color: var(--color-primary);"
  >
    Neem contact op
  </a>
</div>

<!-- Overlay -->
<div
  id="nav-overlay"
  class="fixed inset-0 bg-black/40 z-30 hidden"
  aria-hidden="true"
></div>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  const overlay = document.getElementById('nav-overlay');
  const h1 = document.getElementById('hamburger-1');
  const h2 = document.getElementById('hamburger-2');
  const h3 = document.getElementById('hamburger-3');

  // Sticky header style
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('nav-scrolled');
    } else {
      header?.classList.remove('nav-scrolled');
    }
  });

  // Mobile menu
  let isOpen = false;

  function openMenu() {
    isOpen = true;
    mobileNav?.classList.add('open');
    overlay?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    toggle?.setAttribute('aria-expanded', 'true');
    mobileNav?.removeAttribute('inert');
    if (h1 && h2 && h3) {
      h1.style.transform = 'rotate(45deg) translate(5px, 5px)';
      h2.style.opacity = '0';
      h3.style.transform = 'rotate(-45deg) translate(5px, -5px)';
    }
  }

  function closeMenu() {
    isOpen = false;
    mobileNav?.classList.remove('open');
    overlay?.classList.add('hidden');
    document.body.style.overflow = '';
    toggle?.setAttribute('aria-expanded', 'false');
    mobileNav?.setAttribute('inert', '');
    if (h1 && h2 && h3) {
      h1.style.transform = '';
      h2.style.opacity = '';
      h3.style.transform = '';
    }
  }

  toggle?.addEventListener('click', () => {
    isOpen ? closeMenu() : openMenu();
  });

  overlay?.addEventListener('click', closeMenu);

  // Close menu when a nav link is clicked
  mobileNav?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
