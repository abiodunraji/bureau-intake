---
import { url } from '../utils/url';
---

<section class="py-24 md:py-32" style="background: var(--color-light);" aria-labelledby="oprichter-heading">
  <div class="max-w-[1200px] mx-auto px-6">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Photo placeholder -->
      <div class="reveal order-2 lg:order-1">
        <div
          class="relative rounded-2xl overflow-hidden"
          style="aspect-ratio: 4/5; background: var(--color-light); border: 1px solid rgba(0,0,0,0.06);"
        >
          <!-- Photo: replace this div with <img> when Iwan's photo is available -->
          <div class="absolute inset-0 flex items-center justify-center" style="background: linear-gradient(135deg, #e8f5e9 0%, #f1f8e9 100%);">
            <div
              class="w-24 h-24 rounded-full flex items-center justify-center"
              style="background: rgba(46,204,113,0.15);"
            >
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-label="Profielfoto oprichter">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            </div>
          </div>

          <div
            class="absolute bottom-6 right-6 w-16 h-16 rounded-full"
            style="background: var(--color-accent); opacity: 0.15;"
            aria-hidden="true"
          ></div>
        </div>
      </div>

      <!-- Copy -->
      <div class="reveal reveal-delay-2 order-1 lg:order-2">
        <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-accent);">Over de oprichter</p>
        <h2 class="mb-6" style="font-size: clamp(1.75rem, 3.5vw, 2.25rem);" id="oprichter-heading">
          Iwan Stepanova
        </h2>

        <div class="space-y-4 mb-8">
          <p class="text-base leading-relaxed" style="color: var(--color-primary);">
            Bureau Intake is opgericht door Iwan Stepanova — marketingspecialist met een focus op de zorgsector. Wij geloven dat fysiotherapeuten hun energie moeten steken in behandelen, niet in marketing.
          </p>
          <p class="text-base leading-relaxed" style="color: var(--color-muted);">
            Na jaren in de zorgsector te hebben gewerkt, weet Iwan precies waar de knelpunten zitten: drukke praktijken die nauwelijks tijd hebben voor hun eigen vindbaarheid, terwijl patiënten wél online zoeken.
          </p>
        </div>

        <a
          href={url('/over')}
          class="inline-flex items-center gap-2 text-sm font-semibold transition-colors duration-200 hover:text-[var(--color-accent-hover)]"
          style="color: var(--color-accent);"
        >
          Lees meer over ons
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
