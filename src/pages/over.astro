---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../utils/url';
---

<BaseLayout
  title="Over ons — Bureau Intake"
  description="Leer Bureau Intake kennen — een marketingbureau dat uitsluitend werkt voor fysiotherapiepraktijken in Nederland."
>

  <!-- Page hero -->
  <section class="over-hero" style="padding-top: 132px; padding-bottom: 0; background: var(--color-white); position: relative; overflow: hidden;">

    <!-- Subtle background blobs -->
    <div class="morph-blob" aria-hidden="true" style="position: absolute; width: 480px; height: 480px; top: -80px; right: -100px; background: var(--color-accent); opacity: 0.035; pointer-events: none;"></div>
    <div class="morph-blob-slow" aria-hidden="true" style="position: absolute; width: 300px; height: 300px; bottom: 0; left: -80px; background: var(--color-accent); opacity: 0.025; pointer-events: none;"></div>

    <!-- Floating nature elements (desktop only) -->
    <div class="over-float over-float-1" aria-hidden="true" style="position: absolute; right: 6%; top: 160px; width: 22px; height: 22px; color: var(--color-accent); opacity: 0.18; pointer-events: none;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="22" x2="12" y2="11"/><path d="M12 11C11 7.5 8 5.5 5 6.5c.3 3.5 2.5 5.5 7 4.5z"/><path d="M12 11c1-3.5 4-5.5 7-4.5-.3 3.5-2.5 5.5-7 4.5z"/></svg>
    </div>
    <div class="over-float over-float-2" aria-hidden="true" style="position: absolute; left: 4%; top: 220px; width: 18px; height: 18px; color: var(--color-accent); opacity: 0.13; pointer-events: none;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2.5"/><ellipse cx="12" cy="5.5" rx="2" ry="3"/><ellipse cx="18.5" cy="12" rx="3" ry="2"/><ellipse cx="12" cy="18.5" rx="2" ry="3"/><ellipse cx="5.5" cy="12" rx="3" ry="2"/></svg>
    </div>

    <div class="max-w-[1200px] mx-auto px-6 pb-12 md:pb-16" style="text-align: center;">
      <p class="over-eyebrow" style="font-family: var(--font-body); font-size: 12px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-accent); margin-bottom: 14px;">Over ons</p>
      <h1 class="over-h1" style="font-size: clamp(2.25rem, 5vw, 3.5rem); max-width: 760px; margin: 0 auto 16px;">
        Bureau Intake helpt fysiotherapiepraktijken meer patiënten te bereiken.
      </h1>
      <p class="over-sub" style="font-size: 17px; color: var(--color-muted); max-width: 520px; line-height: 1.65; margin: 0 auto;">
        Uitsluitend voor fysiotherapie. Persoonlijk. Zonder jargon.
      </p>
    </div>
  </section>

  <!-- Divider line -->
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">
    <div style="height: 1px; background: linear-gradient(to right, var(--color-accent), rgba(46,204,113,0.08), transparent);"></div>
  </div>

  <!-- Vision section -->
  <section style="padding: 64px 24px 72px; background: var(--color-white);">
    <div class="max-w-[1200px] mx-auto">
      <div class="reveal" style="max-width: 760px;">
        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 20px;">
          <div style="width: 28px; height: 1.5px; background: var(--color-accent);"></div>
          <span style="font-family: var(--font-body); font-size: 12px; font-weight: 600; letter-spacing: 0.12em; color: var(--color-accent); text-transform: uppercase;">Onze missie</span>
        </div>
        <p style="font-size: clamp(16px, 1.6vw, 18px); line-height: 1.75; color: var(--color-primary); margin-bottom: 20px;">
          Bureau Intake is opgericht met één doel: fysiotherapiepraktijken helpen die het verdienen zichtbaar te zijn. De praktijken waar patiënten na hun behandeling opgelucht naar huis gaan — maar die online nauwelijks te vinden zijn.
        </p>
        <p style="font-size: clamp(16px, 1.6vw, 18px); line-height: 1.75; color: var(--color-primary);">
          We werken uitsluitend voor fysiotherapie. Dat is een bewuste keuze. Hoe beter wij jullie wereld begrijpen — de agenda, de verwijzingen, de concurrenten in de buurt — hoe beter wij kunnen leveren. Lokale vindbaarheid is geen truc. Het is een combinatie van een sterk Google-profiel, echte reviews en een website die patiënten vertrouwen geeft op het moment dat ze zoeken.
        </p>
      </div>
    </div>
  </section>

  <!-- How we work -->
  <section style="padding: 64px 24px 72px; background: var(--color-light);">
    <div class="max-w-[1200px] mx-auto">
      <div class="reveal" style="margin-bottom: 36px;">
        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
          <div style="width: 28px; height: 1.5px; background: var(--color-accent);"></div>
          <span style="font-family: var(--font-body); font-size: 12px; font-weight: 600; letter-spacing: 0.12em; color: var(--color-accent); text-transform: uppercase;">Hoe wij werken</span>
        </div>
        <h2 style="font-size: clamp(22px, 3vw, 30px); font-weight: 700; letter-spacing: -0.02em; color: var(--color-primary); max-width: 480px; margin: 0;">
          Direct, transparant en volledig gericht op resultaat.
        </h2>
      </div>
      <div class="reveal reveal-delay-1 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { title: 'Persoonlijk', body: 'Geen accountmanager die belt. Je werkt direct met de oprichter.' },
          { title: 'Transparant', body: 'Je ziet precies wat we doen en wat het oplevert.' },
          { title: 'Maandelijks opzegbaar', body: 'We verdienen je vertrouwen elke maand opnieuw.' },
          { title: 'Zorgsector first', body: 'We begrijpen de context van jouw praktijk.' },
        ].map(val => (
          <div class="p-6 rounded-xl" style="background: var(--color-white); transition: box-shadow 0.2s ease, transform 0.2s ease;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 16px rgba(0,0,0,0.07)'" onmouseout="this.style.transform=''; this.style.boxShadow=''">
            <p class="text-sm font-semibold mb-2" style="font-family: var(--font-heading);">{val.title}</p>
            <p class="text-sm" style="color: var(--color-muted); line-height: 1.65;">{val.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About Iwan (last) -->
  <section style="padding: 72px 24px 100px; background: var(--color-white);">
    <div style="max-width: 760px; margin: 0 auto;">

      <!-- Section label -->
      <div class="reveal" style="display: flex; align-items: center; gap: 10px; margin-bottom: 32px;">
        <div style="width: 28px; height: 1.5px; background: var(--color-accent);"></div>
        <span style="font-family: var(--font-body); font-size: 12px; font-weight: 600; letter-spacing: 0.12em; color: var(--color-accent); text-transform: uppercase;">Over de oprichter</span>
      </div>

      <!-- Compact founder card -->
      <div class="reveal reveal-delay-1" style="display: flex; align-items: center; gap: 20px; padding: 20px 24px; border-radius: 16px; background: var(--color-light); margin-bottom: 32px;">
        <img
          src={url('/iwan-stepanova.webp')}
          alt="Iwan Stepanova, oprichter van Bureau Intake"
          loading="lazy"
          decoding="async"
          width="88"
          height="88"
          style="width: 88px; height: 88px; border-radius: 12px; object-fit: cover; object-position: center top; flex-shrink: 0; display: block;"
        />
        <div>
          <p style="font-family: var(--font-heading); font-size: 17px; font-weight: 700; color: var(--color-primary); margin-bottom: 4px;">Iwan Stepanova</p>
          <p style="font-family: var(--font-body); font-size: 13px; color: var(--color-muted);">Oprichter — Bureau Intake</p>
          <div style="display: flex; align-items: center; gap: 8px; margin-top: 8px;">
            <div style="width: 18px; height: 1px; background: var(--color-accent);"></div>
            <span style="font-family: var(--font-body); font-size: 11px; font-weight: 600; letter-spacing: 0.1em; color: var(--color-accent); text-transform: uppercase;">Uitsluitend fysiotherapie</span>
          </div>
        </div>
      </div>

      <!-- About-me intro quote -->
      <div class="reveal reveal-delay-2" style="padding: 28px; border-radius: 16px; background: var(--color-light); margin-bottom: 32px; border-left: 3px solid var(--color-accent);">
        <p style="font-size: 16px; line-height: 1.75; color: var(--color-primary); font-style: italic; margin: 0;">
          "Tijdens mijn werk bij marketingbureaus viel me iets op: fysiotherapeuten leveren uitstekende zorg, maar online is dat bijna nooit zichtbaar. Geen goed Google-profiel, geen reviews, een website die niemand vindt. Niet omdat ze het niet belangrijk vinden, maar omdat ze er simpelweg geen tijd voor hebben. Bureau Intake is er om dat op te lossen."
        </p>
      </div>

      <!-- Main story paragraphs -->
      <div class="reveal reveal-delay-3 space-y-5 text-base leading-relaxed" style="color: var(--color-primary);">
        <p>
          Ik heb Bureau Intake opgericht omdat ik iets zag dat niet klopte. Fysiotherapeuten die uitstekende zorg leveren, maar online nauwelijks te vinden zijn. Niet omdat ze het niet proberen, maar omdat hun tijd opgaat aan wat echt belangrijk is: hun patiënten.
        </p>
        <p>
          Tijdens mijn werk bij een marketingbureau werd dit patroon steeds duidelijker. Praktijken met een halfleeg Google-profiel, zonder reviews, met een website die al jaren niet is aangeraakt. Terwijl 74% van de patiënten tegenwoordig zelf online zoekt, zonder verwijzing van de huisarts.
        </p>
        <p>
          Bureau Intake bestaat om dat gat te dichten. Wij werken uitsluitend voor fysiotherapiepraktijken. Dat is een bewuste keuze: hoe beter wij jullie wereld begrijpen, hoe beter de resultaten.
        </p>
      </div>

      <!-- CTA -->
      <div class="reveal reveal-delay-4 mt-10">
        <a
          href={url('/contact')}
          class="inline-block text-base font-semibold px-8 py-4 rounded-lg transition-all duration-200 hover:scale-[1.02]"
          style="background: var(--color-accent); color: white;"
          onmouseover="this.style.background='var(--color-accent-hover)'"
          onmouseout="this.style.background='var(--color-accent)'"
        >
          Neem contact op
        </a>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  /* Over page hero animations */
  .over-eyebrow,
  .over-h1,
  .over-sub {
    opacity: 0;
    transform: translateY(20px);
    transition-property: opacity, transform;
    transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    transition-duration: 900ms;
    will-change: transform, opacity;
  }

  .over-eyebrow.visible { opacity: 1; transform: translateY(0); transition-delay: 0ms; }
  .over-h1.visible      { opacity: 1; transform: translateY(0); transition-delay: 120ms; }
  .over-sub.visible     { opacity: 1; transform: translateY(0); transition-delay: 240ms; }

  /* Floating icons — desktop only */
  @media (max-width: 768px) {
    .over-float { display: none; }
  }

  .over-float-1 { animation: floatEl 7s ease-in-out infinite; }
  .over-float-2 { animation: floatEl 9s ease-in-out 1.5s infinite; }
</style>

<script>
  const overEls = document.querySelectorAll('.over-eyebrow, .over-h1, .over-sub');
  const overObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          overObs.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  overEls.forEach((el) => overObs.observe(el));
</script>
