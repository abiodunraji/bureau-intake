<!--
  FORM BACKEND: Netlify Forms
  - Works automatically on Netlify hosting (no config needed)
  - Submissions land in Netlify dashboard → Forms
  - Add email notifications in: Netlify → Site → Forms → Notifications

  NOT on Netlify? Use Formspree instead:
  1. Create account at formspree.io, create a form, copy the ID
  2. Change the form action to: action="https://formspree.io/f/YOUR_ID"
  3. Remove data-netlify and the hidden input below
  4. Change the fetch URL in the script to: 'https://formspree.io/f/YOUR_ID'
-->

<form
  id="contact-form"
  name="contact"
  method="POST"
  data-netlify="true"
  data-netlify-honeypot="bot-field"
  class="space-y-5"
  novalidate
>
  <!-- Netlify hidden fields -->
  <input type="hidden" name="form-name" value="contact" />
  <p class="hidden" aria-hidden="true">
    <label>Niet invullen: <input name="bot-field" /></label>
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <!-- Naam -->
    <div>
      <label for="naam" class="block text-sm font-medium mb-1.5" style="color: var(--color-primary);">
        Naam <span aria-hidden="true" style="color: var(--color-accent);">*</span>
      </label>
      <input
        type="text"
        id="naam"
        name="naam"
        required
        autocomplete="name"
        class="w-full px-4 py-3 rounded-lg text-sm outline-none transition-all duration-200"
        style="
          border: 1.5px solid rgba(0,0,0,0.12);
          background: white;
          color: var(--color-primary);
          font-family: var(--font-body);
        "
        placeholder="Voor- en achternaam"
      />
    </div>

    <!-- Praktijknaam -->
    <div>
      <label for="praktijknaam" class="block text-sm font-medium mb-1.5" style="color: var(--color-primary);">
        Praktijknaam <span aria-hidden="true" style="color: var(--color-accent);">*</span>
      </label>
      <input
        type="text"
        id="praktijknaam"
        name="praktijknaam"
        required
        autocomplete="organization"
        class="w-full px-4 py-3 rounded-lg text-sm outline-none transition-all duration-200"
        style="
          border: 1.5px solid rgba(0,0,0,0.12);
          background: white;
          color: var(--color-primary);
          font-family: var(--font-body);
        "
        placeholder="Naam van je praktijk"
      />
    </div>
  </div>

  <!-- E-mailadres -->
  <div>
    <label for="email" class="block text-sm font-medium mb-1.5" style="color: var(--color-primary);">
      E-mailadres <span aria-hidden="true" style="color: var(--color-accent);">*</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      autocomplete="email"
      class="w-full px-4 py-3 rounded-lg text-sm outline-none transition-all duration-200"
      style="
        border: 1.5px solid rgba(0,0,0,0.12);
        background: white;
        color: var(--color-primary);
        font-family: var(--font-body);
      "
      placeholder="jouw@praktijk.nl"
    />
  </div>

  <!-- Telefoonnummer -->
  <div>
    <label for="telefoon" class="block text-sm font-medium mb-1.5" style="color: var(--color-primary);">
      Telefoonnummer <span class="text-xs font-normal" style="color: var(--color-muted);">(optioneel)</span>
    </label>
    <input
      type="tel"
      id="telefoon"
      name="telefoon"
      autocomplete="tel"
      class="w-full px-4 py-3 rounded-lg text-sm outline-none transition-all duration-200"
      style="
        border: 1.5px solid rgba(0,0,0,0.12);
        background: white;
        color: var(--color-primary);
        font-family: var(--font-body);
      "
      placeholder="06 00 000 000"
    />
  </div>

  <!-- Bericht -->
  <div>
    <label for="bericht" class="block text-sm font-medium mb-1.5" style="color: var(--color-primary);">
      Bericht <span class="text-xs font-normal" style="color: var(--color-muted);">(optioneel)</span>
    </label>
    <textarea
      id="bericht"
      name="bericht"
      rows="4"
      class="w-full px-4 py-3 rounded-lg text-sm outline-none transition-all duration-200 resize-none"
      style="
        border: 1.5px solid rgba(0,0,0,0.12);
        background: white;
        color: var(--color-primary);
        font-family: var(--font-body);
      "
      placeholder="Vertel ons kort iets over je praktijk of je vraag..."
    ></textarea>
  </div>

  <!-- Submit -->
  <button
    type="submit"
    id="submit-btn"
    class="w-full sm:w-auto px-10 py-4 rounded-lg text-base font-semibold transition-all duration-200 hover:scale-[1.01]"
    style="background: var(--color-accent); color: white;"
    onmouseover="this.style.background='var(--color-accent-hover)'"
    onmouseout="this.style.background='var(--color-accent)'"
  >
    Verstuur
  </button>

  <!-- Feedback -->
  <div id="form-feedback" class="hidden text-sm px-4 py-3 rounded-lg" role="alert" aria-live="polite"></div>
</form>

<style>
  input:focus, textarea:focus {
    border-color: var(--color-accent) !important;
    box-shadow: 0 0 0 3px rgba(46, 204, 113, 0.12);
  }

  input.error, textarea.error {
    border-color: #e74c3c !important;
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const feedback = document.getElementById('form-feedback') as HTMLElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const naam = (form.querySelector('#naam') as HTMLInputElement).value.trim();
    const praktijknaam = (form.querySelector('#praktijknaam') as HTMLInputElement).value.trim();
    const email = (form.querySelector('#email') as HTMLInputElement).value.trim();

    if (!naam || !praktijknaam || !email) {
      showFeedback('Vul alle verplichte velden in.', false);
      return;
    }

    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showFeedback('Voer een geldig e-mailadres in.', false);
      return;
    }

    submitBtn.textContent = 'Versturen...';
    submitBtn.disabled = true;

    try {
      const data = new FormData(form);
      const response = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(data as unknown as Record<string, string>).toString(),
      });

      if (response.ok) {
        showFeedback('Bedankt! We nemen zo snel mogelijk contact met je op.', true);
        form.reset();
      } else {
        throw new Error('Network response was not ok');
      }
    } catch {
      showFeedback('Er ging iets mis. Probeer het opnieuw of mail ons direct op info@bureauintake.nl.', false);
    } finally {
      submitBtn.textContent = 'Verstuur';
      submitBtn.disabled = false;
    }
  });

  function showFeedback(message: string, success: boolean) {
    feedback.textContent = message;
    feedback.style.background = success ? 'rgba(46,204,113,0.1)' : 'rgba(231,76,60,0.08)';
    feedback.style.color = success ? 'var(--color-accent)' : '#e74c3c';
    feedback.style.border = success ? '1px solid rgba(46,204,113,0.2)' : '1px solid rgba(231,76,60,0.15)';
    feedback.classList.remove('hidden');
  }
</script>
