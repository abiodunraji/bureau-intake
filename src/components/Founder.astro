---
import { url } from '../utils/url';
---

<section style="padding: 100px 24px; background: var(--color-white); overflow: hidden;" aria-labelledby="oprichter-heading">
  <div style="max-width: 1100px; margin: 0 auto;">

    <div class="reveal" style="display: flex; gap: 48px; align-items: center; flex-wrap: wrap;">

      <!-- Photo placeholder with IS initials + morph blob -->
      <div style="position: relative; width: 200px; flex-shrink: 0;">
        <!-- Morph blob behind placeholder -->
        <div class="morph-blob" aria-hidden="true" style="position: absolute; width: 150px; height: 150px; top: -20px; left: -20px; background: var(--color-accent); opacity: 0.06; pointer-events: none;"></div>

        <img src={url('/iwan-stepanova.webp')} alt="Iwan Stepanova, oprichter van Bureau Intake" style="width: 200px; height: 250px; object-fit: cover; object-position: center top; border-radius: 20px; display: block;" />
      </div>

      <!-- Copy -->
      <div style="flex: 1; min-width: 260px;">
        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
          <div style="width: 28px; height: 1.5px; background: var(--color-accent);"></div>
          <span style="font-family: var(--font-body); font-size: 12px; font-weight: 600; letter-spacing: 0.12em; color: var(--color-accent); text-transform: uppercase;">Over de oprichter</span>
        </div>

        <h2 id="oprichter-heading" style="font-family: var(--font-heading); font-size: 32px; font-weight: 700; color: var(--color-primary); margin-bottom: 16px; letter-spacing: -0.02em;">
          Iwan Stepanova
        </h2>

        <p style="font-size: 15px; line-height: 1.7; color: var(--color-muted); margin-bottom: 12px;">
          Bureau Intake is opgericht door Iwan Stepanova — marketingspecialist met een focus op de zorgsector. Wij geloven dat fysiotherapeuten hun energie moeten steken in behandelen, niet in marketing.
        </p>
        <p style="font-size: 15px; line-height: 1.7; color: var(--color-muted); margin-bottom: 24px;">
          Tijdens mijn werk bij een marketingbureau zag ik keer op keer hoe slecht fysiotherapiepraktijken online zichtbaar waren — terwijl het juist die praktijken zijn waar patiënten elke dag naar zoeken.
        </p>

        <a
          href={url('/over')}
          style="font-family: var(--font-body); font-size: 14px; font-weight: 600; color: var(--color-accent); text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: color 0.2s ease;"
          onmouseover="this.style.color='var(--color-accent-hover)'"
          onmouseout="this.style.color='var(--color-accent)'"
        >
          Lees meer over ons →
        </a>
      </div>
    </div>
  </div>
</section>
