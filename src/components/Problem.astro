---
const problems = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M11 8v3l2 2"/></svg>`,
    title: 'Je Google-profiel is onvolledig of niet geclaimd',
    body: 'Patiënten zien je concurrent eerder — alleen omdat die een beter ingevuld profiel heeft. Niet omdat die beter is.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 10h8M8 13h5"/></svg>`,
    title: 'Je hebt weinig of geen reviews',
    body: '9 op de 10 patiënten leest reviews voordat ze bellen. Geen reviews betekent geen vertrouwen — en geen afspraak.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>`,
    title: 'Je website is verouderd of onzichtbaar in Google',
    body: 'Potentiële patiënten zoeken op "fysiotherapeut + [jouw stad]" — en jij staat niet op pagina 1. Ze bellen iemand anders.',
  },
];
---

<section class="py-24 md:py-32" style="background: var(--color-light);" aria-labelledby="probleem-heading">
  <div class="max-w-[1200px] mx-auto px-6">

    <!-- Section label -->
    <p class="reveal text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-accent);">Herkenbaar?</p>

    <h2 class="reveal reveal-delay-1 mb-4 max-w-2xl" style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);" id="probleem-heading">
      Terwijl jij behandelt, loopt de agenda van je concurrent vol
    </h2>

    <p class="reveal reveal-delay-2 text-base mb-16 max-w-xl" style="color: var(--color-muted);">
      Niet door beter te zijn. Maar door beter gevonden te worden.
    </p>

    <!-- Problems — asymmetric vertical stack on desktop -->
    <div class="space-y-6">
      {problems.map((problem, i) => (
        <div
          class={`reveal reveal-delay-${i + 1} group flex gap-6 p-7 rounded-xl`}
          style="background: white; box-shadow: 0 2px 8px rgba(0,0,0,0.06);"
        >
          <!-- Icon -->
          <div
            class="flex-shrink-0 w-12 h-12 rounded-lg flex items-center justify-center"
            style="background: rgba(46,204,113,0.08); color: var(--color-accent);"
            set:html={problem.icon}
          />

          <!-- Text -->
          <div class="flex-1">
            <h3 class="text-base font-semibold mb-1" style="font-family: var(--font-heading);">{problem.title}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-muted);">{problem.body}</p>
          </div>

          <!-- Number -->
          <div class="hidden md:flex flex-shrink-0 text-5xl font-bold self-center" style="font-family: var(--font-heading); color: rgba(46,204,113,0.12); letter-spacing: -0.04em;">
            {String(i + 1).padStart(2, '0')}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
