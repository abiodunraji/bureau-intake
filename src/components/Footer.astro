---
import { url } from '../utils/url';
const year = new Date().getFullYear();
---

<footer style="background: var(--color-dark); color: var(--color-dark-text);">
  <div class="max-w-[1200px] mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">

      <!-- Brand -->
      <div>
        <a href={url('/')} aria-label="Bureau Intake — home" style="display: inline-flex; align-items: center; margin-bottom: 12px; text-decoration: none;">
          <picture>
            <source srcset={url('/logo-bi-white.webp')} type="image/webp" />
            <img src={url('/logo-bi-white.png')} alt="Bureau Intake" width="186" height="40" loading="lazy" decoding="async" style="height: 40px; width: 186px; display: block;" />
          </picture>
        </a>
        <p class="text-sm leading-relaxed" style="color: #A0A6B0;">
          Wij maken fysiotherapiepraktijken zichtbaar in Google, Google Maps en AI-zoekmachines.
        </p>
      </div>

      <!-- Nav -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: #A0A6B0;">Navigatie</p>
        <nav class="flex flex-col gap-3" aria-label="Footer navigatie">
          <a href={url('/')} class="text-sm transition-colors duration-200 hover:text-[var(--color-accent)]" style="color: var(--color-dark-text);">Home</a>
          <a href={url('/webdesign')} class="text-sm transition-colors duration-200 hover:text-[var(--color-accent)]" style="color: var(--color-dark-text);">Webdesign</a>
          <a href={url('/over')} class="text-sm transition-colors duration-200 hover:text-[var(--color-accent)]" style="color: var(--color-dark-text);">Over ons</a>
          <a href={url('/contact')} class="text-sm transition-colors duration-200 hover:text-[var(--color-accent)]" style="color: var(--color-dark-text);">Contact</a>
        </nav>
      </div>

      <!-- Contact -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: #A0A6B0;">Contact</p>
        <div class="flex flex-col gap-3">
          <a href="mailto:hallo@bureauintake.nl" class="text-sm transition-colors duration-200 hover:text-[var(--color-accent)]" style="color: var(--color-dark-text);">
            hallo@bureauintake.nl
          </a>
          <div>
            <p class="text-sm" style="color: var(--color-dark-text);">Madeliefstraat 13</p>
            <p class="text-sm" style="color: var(--color-dark-text);">1817 CG Alkmaar</p>
          </div>
          <a
            href="https://linkedin.com/company/bureau-intake"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm transition-colors duration-200 hover:text-[var(--color-accent)]"
            style="color: var(--color-dark-text);"
            aria-label="Bureau Intake op LinkedIn"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2" style="border-top: 1px solid rgba(255,255,255,0.08);">
      <p class="text-xs" style="color: #A0A6B0;">© {year} Bureau Intake. Alle rechten voorbehouden.</p>
      <p class="text-xs" style="color: #A0A6B0;">KvK: 90576063</p>
    </div>
  </div>
</footer>
