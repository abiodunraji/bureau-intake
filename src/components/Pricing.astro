---
import { url } from '../utils/url';
import { faqs } from '../data/faqs';

const includes = [
  'Zichtbaar worden in Google Maps en AI-zoekmachines',
  'Een professioneel en compleet Google Bedrijfsprofiel',
  'Meer en betere reviews van patiënten',
  'Een website die gevonden wordt',
  'Maandelijkse rapportage met concrete resultaten',
];
---

<section style="padding: 100px 24px; background: white;" aria-labelledby="pricing-heading">
  <div style="max-width: 680px; margin: 0 auto;">

    <!-- Header -->
    <div class="reveal" style="text-align: center; margin-bottom: 48px;">
      <span style="font-family: var(--font-body); font-size: 12px; font-weight: 600; letter-spacing: 0.12em; color: var(--color-accent-text); text-transform: uppercase;">Tarief</span>
      <h2 id="pricing-heading" style="font-family: var(--font-heading); font-size: clamp(26px, 4vw, 40px); font-weight: 700; line-height: 1.15; margin-top: 12px; margin-bottom: 12px; letter-spacing: -0.02em;">
        Eén helder tarief. Geen verrassingen.
      </h2>
      <p style="font-size: 15px; color: var(--color-muted); max-width: 460px; margin: 0 auto; line-height: 1.6;">
        Twee extra patiënten per maand? Dat is break-even.
      </p>
    </div>

    <!-- Pricing card -->
    <div class="reveal reveal-delay-1">
      <div style="background: var(--color-white); border-radius: 24px; padding: 48px 36px; border: 1.5px solid rgba(46,204,113,0.12); position: relative; overflow: hidden;">

        <!-- Morph blob inside card -->
        <div class="morph-blob" aria-hidden="true" style="position: absolute; width: 200px; height: 200px; top: -60px; right: -60px; background: var(--color-accent); opacity: 0.04; pointer-events: none;"></div>

        <!-- Price -->
        <div style="text-align: center; margin-bottom: 36px; position: relative;">
          <div style="font-family: var(--font-heading); font-size: clamp(44px, 8vw, 60px); font-weight: 800; color: var(--color-primary); letter-spacing: -0.03em; line-height: 1;">
            €590<span style="font-size: clamp(18px, 3vw, 24px); font-weight: 400; color: var(--color-muted);"> /maand</span>
          </div>
          <p style="font-family: var(--font-body); font-size: 14px; color: var(--color-muted); margin-top: 10px;">
            Maandelijks opzegbaar · Geen jaarcontract · Geen opstartkosten
          </p>
        </div>

        <!-- Included items -->
        <div style="display: flex; flex-direction: column; gap: 14px; margin-bottom: 36px;">
          {includes.map(item => (
            <div style="display: flex; gap: 12px; align-items: flex-start;">
              <div style="width: 20px; height: 20px; border-radius: 50%; flex-shrink: 0; background: rgba(46,204,113,0.1); display: flex; align-items: center; justify-content: center; margin-top: 1px;">
                <span style="color: var(--color-accent); font-size: 11px; font-weight: 700;">✓</span>
              </div>
              <span style="font-family: var(--font-body); font-size: 14px; color: var(--color-primary); line-height: 1.5;">{item}</span>
            </div>
          ))}
        </div>

        <!-- CTA -->
        <div style="text-align: center;">
          <a
            href={url('/contact')}
            style="font-family: var(--font-body); font-size: 15px; font-weight: 600; color: var(--color-primary); background: var(--color-accent); padding: 16px 40px; border-radius: 10px; text-decoration: none; display: inline-block; box-shadow: 0 4px 20px rgba(46,204,113,0.2); transition: all 0.25s ease;"
            onmouseover="this.style.background='var(--color-accent-hover)'; this.style.transform='translateY(-1px)'; this.style.boxShadow='0 8px 28px rgba(46,204,113,0.3)';"
            onmouseout="this.style.background='var(--color-accent)'; this.style.transform=''; this.style.boxShadow='0 4px 20px rgba(46,204,113,0.2)';"
          >
            Plan een kennismaking
          </a>
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <div class="reveal reveal-delay-2" style="margin-top: 48px;">
      <h3 style="font-family: var(--font-body); font-size: 16px; font-weight: 700; color: var(--color-primary); margin-bottom: 20px;">Veelgestelde vragen</h3>

      <div id="faq-list">
        {faqs.map((faq, i) => (
          <div class="faq-item" style="border-bottom: 1px solid rgba(0,0,0,0.06);" data-index={i}>
            <button
              class="faq-trigger"
              style="width: 100%; padding: 20px 0; background: none; border: none; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 16px; text-align: left;"
              aria-expanded="false"
            >
              <span class="faq-question" style="font-family: var(--font-body); font-weight: 600; color: var(--color-primary);">{faq.question}</span>
              <span class="faq-icon-btn" style="width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0; background: rgba(46,204,113,0.08); color: var(--color-accent); display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; font-size: 18px; font-weight: 300; line-height: 1;">+</span>
            </button>
            <div class="faq-answer" style="padding: 0;">
              <p class="faq-body" style="font-family: var(--font-body); color: var(--color-muted); line-height: 1.7; padding-bottom: 20px; margin: 0;">{faq.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const triggers = document.querySelectorAll('.faq-trigger');

  triggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item   = trigger.closest('.faq-item') as HTMLElement;
      const answer = item.querySelector('.faq-answer') as HTMLElement;
      const btn    = item.querySelector('.faq-icon-btn') as HTMLElement;
      const isOpen = item.classList.contains('open');

      // Close all
      document.querySelectorAll('.faq-item').forEach((el) => {
        el.classList.remove('open');
        const ans = el.querySelector('.faq-answer') as HTMLElement;
        const b   = el.querySelector('.faq-icon-btn') as HTMLElement;
        if (ans) ans.classList.remove('open');
        if (b)   { b.textContent = '+'; b.style.background = 'rgba(46,204,113,0.08)'; b.style.color = 'var(--color-accent)'; }
        const t = el.querySelector('.faq-trigger') as HTMLElement;
        if (t) t.setAttribute('aria-expanded', 'false');
      });

      if (!isOpen) {
        item.classList.add('open');
        answer.classList.add('open');
        trigger.setAttribute('aria-expanded', 'true');
        if (btn) { btn.textContent = '−'; btn.style.background = 'var(--color-accent)'; btn.style.color = 'white'; }
      }
    });
  });
</script>
