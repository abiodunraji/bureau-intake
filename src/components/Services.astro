---
const services = [
  {
    emoji: '📍',
    title: 'Zichtbaar in Google Maps',
    body: 'Wij optimaliseren je Google Bedrijfsprofiel zodat patiënten je vinden als ze zoeken in jouw regio — volledig, up-to-date, en beter dan je concurrent.',
  },
  {
    emoji: '⭐',
    title: 'Meer en betere reviews',
    body: 'Wij helpen je met een strategie om reviews te verzamelen en reageren namens je praktijk — zodat nieuwe patiënten direct vertrouwen voelen.',
  },
  {
    emoji: '🔗',
    title: 'Overal dezelfde gegevens',
    body: 'Wij zorgen dat je naam, adres en telefoonnummer overal correct en consistent staan — van Zorgkaart Nederland tot Google en online gidsen.',
  },
  {
    emoji: '💻',
    title: 'Een website die werkt',
    body: 'Wij optimaliseren je bestaande site zodat Google én patiënten je beter vinden. Sneller, technisch correct, en met de juiste zoektermen voor jouw regio.',
  },
];
---

<section style="padding: 100px 24px; background: white;" aria-labelledby="diensten-heading">
  <div style="max-width: 1100px; margin: 0 auto;">

    <!-- Section label -->
    <div class="reveal" style="display: flex; align-items: center; gap: 10px; margin-bottom: 16px;">
      <div style="width: 28px; height: 1.5px; background: var(--color-accent);"></div>
      <span style="font-family: var(--font-body); font-size: 12px; font-weight: 600; letter-spacing: 0.12em; color: var(--color-accent); text-transform: uppercase;">Wat wij doen</span>
    </div>

    <h2 class="reveal reveal-delay-1" id="diensten-heading" style="font-size: clamp(26px, 4vw, 42px); font-weight: 700; line-height: 1.12; letter-spacing: -0.02em; margin-bottom: 56px; max-width: 520px;">
      Meer patiënten, <span style="font-style: italic; color: #9ca3af; font-weight: 400;">zonder dat je er zelf aan hoeft te denken.</span>
    </h2>

    <!-- Auto-fit card grid -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px;">
      {services.map((service, i) => (
        <div
          class={`reveal reveal-delay-${i + 1} service-card`}
          style="padding: 32px 28px; border-radius: 16px; background: var(--color-white); border: 1px solid rgba(0,0,0,0.04); height: 100%; cursor: default;"
          onmouseover="this.style.borderColor='rgba(46,204,113,0.15)'"
          onmouseout="this.style.borderColor='rgba(0,0,0,0.04)'"
        >
          <div style="font-size: 28px; margin-bottom: 16px;">{service.emoji}</div>
          <h3 style="font-family: var(--font-body); font-size: 17px; font-weight: 700; color: var(--color-primary); margin-bottom: 8px;">{service.title}</h3>
          <p style="font-size: 14px; line-height: 1.65; color: var(--color-muted); margin: 0;">{service.body}</p>
        </div>
      ))}
    </div>

    <!-- AI subtext -->
    <div class="reveal reveal-delay-5" style="margin-top: 32px; padding: 14px 20px; background: rgba(46,204,113,0.05); border-radius: 12px; border: 1px solid rgba(46,204,113,0.1); display: inline-flex; align-items: center; gap: 8px;">
      <span style="font-size: 14px;" aria-hidden="true">🤖</span>
      <span style="font-family: var(--font-body); font-size: 14px; color: var(--color-primary);">
        Plus: wij bereiden je praktijk voor op <strong>AI-zoekmachines</strong> — de volgende generatie vindbaarheid.
      </span>
    </div>
  </div>
</section>
